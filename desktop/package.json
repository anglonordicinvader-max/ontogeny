{
  "name": "ontogeny",
  "version": "1.0.0",
  "description": "Ontogeny - AI-Native Research Workstation",
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:main": "cd main && npm run dev",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "cd renderer && npm run build",
    "build:main": "cd main && npm run build",
    "package": "npm run build && electron-builder --win",
    "package:portable": "npm run build && electron-builder --win portable",
    "package:installer": "npm run build && electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "concurrently": "^9.0.0"
  },
  "build": {
    "appId": "com.ontogeny.app",
    "productName": "Ontogeny",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "preload/**/*",
      "backend/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/ontogeny-backend.exe",
        "to": "backend/ontogeny-backend.exe"
      },
      {
        "from": "../backend/blender",
        "to": "backend/blender"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "renderer/public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ontogeny"
    },
    "publish": {
      "provider": "github",
      "owner": "anglonordicinvader-max",
      "repo": "ontogeny"
    }
  }
}
