# Proxy Configuration
PROXY_ENABLED=true
PROXY_REQUIRED=true

# Option 1: Static proxy list
PROXY_PROXIES=["http://proxy1:8080", "socks5://proxy2:1080"]

# Option 2: Proxy file (one per line)
# PROXY_PROXY_FILE=./proxies.txt

# Auto-refresh (fetches new proxies when pool runs low)
PROXY_AUTO_REFRESH=true
PROXY_MIN_PROXIES=10
PROXY_REFRESH_INTERVAL=300
PROXY_FETCH_FREE_PROXIES=true

# Proxy Authentication (if using same credentials for all)
PROXY_USERNAME=
PROXY_PASSWORD=

# Proxy Rotation & Health
PROXY_ROTATE_EVERY=10
PROXY_MAX_FAILURES=3
PROXY_HEALTH_CHECK_INTERVAL=300

# Paid Proxy Providers (optional - more reliable)
# PROXY_PROVIDER_NAME=brightdata
# PROXY_PROVIDER_API_KEY=your_api_key
# PROXY_PROVIDER_HOST=brd.superproxy.io
# PROXY_PROVIDER_PORT=22225

# Crawler Settings
CRAWLER_REQUESTS_PER_SECOND=5.0
CRAWLER_BURST_SIZE=25
CRAWLER_MIN_DELAY=1.0
CRAWLER_MAX_DELAY=3.0

# API Keys (optional - agent works without them)
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=
PASTEBIN_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# LLM Settings (routine — llama3.2 for cheap/free tasks)
LLM_MODEL=llama3.2
LLM_API_KEY=ollama
LLM_API_BASE=http://localhost:11434/v1

# Heavy LLM (DeepSeek-V2 236B - strong reasoning & code)
# HEAVY_LLM_ENABLED=true
# HEAVY_LLM_MODEL=deepseek-v2:236b
# HEAVY_LLM_API_KEY=ollama
# HEAVY_LLM_API_BASE=http://localhost:11434/v1

# Storage
STORAGE_DATABASE_URL=sqlite+aiosqlite:///./crawler.db
